# Cargo Stats - Configuracoes
# Copie para .env e ajuste conforme necessario

# Porta do servidor (padrao: 3000)
PORT=3000

# Caminho do banco de dados SQLite
CARGOSTATS_DB_PATH=./data.db

# Caminho dos uploads de fotos/logos
CARGOSTATS_UPLOADS_PATH=./uploads

# Modo de execucao (production/development)
NODE_ENV=production

# Habilitar logs detalhados (true/false)
DEBUG=false

# URL do servidor de telemetria ETS2/ATS
# ETS2_SERVER_URL=http://localhost:25555
